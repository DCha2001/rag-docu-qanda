# PostgreSQL connection string
# Neon: copy from dashboard → Connection Details → Connection string
# Local Docker: postgresql://postgres:postgres@localhost:5432/aidocureader
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Claude model (optional — defaults to claude-haiku-4-5-20251001)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Application mode: production | development (affects log format)
MODE=production

# Comma-separated list of allowed frontend origins for CORS
# Add your Vercel deployment URL here
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Supabase project URL — found in Supabase dashboard → Settings → API
# Used to fetch the JWKS public key for ES256 JWT verification (no secret needed)
SUPABASE_URL=https://your-project-ref.supabase.co
